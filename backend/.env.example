# DeadlineAI Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# Server Configuration
# =============================================
PORT=5000

# =============================================
# Google AI Studio (Gemini API)
# Get your key: https://aistudio.google.com/apikey
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================
# Firebase Configuration
# Option 1: Paste full service account JSON (recommended for Cloud Run)
# =============================================
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Option 2: Just set the Project ID (for local dev with ADC)
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# =============================================
# Google OAuth2 (for Calendar & Tasks API)
# Create credentials: https://console.cloud.google.com/apis/credentials
# =============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/callback

# =============================================
# Frontend URL (for CORS)
# =============================================
FRONTEND_URL=http://localhost:5173
